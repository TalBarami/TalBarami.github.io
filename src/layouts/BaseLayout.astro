---
import '../styles/global.css';
import '../styles/print.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Social {
  label: string;
  url: string;
  icon: string;
  rel?: string;
}

interface Props {
  title: string;
  description?: string;
  profile: {
    name: string;
    cv: string;
    socials: Social[];
    analytics?: { gaMeasurementId?: string };
  };
}

const { title, description = '', profile } = Astro.props;
const gaId = profile.analytics?.gaMeasurementId;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Google Analytics (production only) -->
    {import.meta.env.PROD && gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
  </head>
  <body>
    <Header name={profile.name} cv={profile.cv} socials={profile.socials} />
    <main>
      <slot />
    </main>
    <Footer name={profile.name} />
  </body>
</html>
